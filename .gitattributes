# Auto detect text files and perform LF normalization
* text=auto

# Source code - force LF line endings
*.cpp text eol=lf
*.h text eol=lf
*.c text eol=lf
*.hpp text eol=lf
*.cs text eol=lf
*.ini text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.txt text eol=lf

# Unreal Engine specific text files
*.uplugin text eol=lf
*.uproject text eol=lf
*.build.cs text eol=lf
*.target.cs text eol=lf

# Shaders
*.usf text eol=lf
*.ush text eol=lf
*.hlsl text eol=lf
*.glsl text eol=lf

# =============================================================================
# Git LFS - Large File Storage
# =============================================================================

# Unreal Engine Assets
*.uasset filter=lfs diff=lfs merge=lfs -text
*.umap filter=lfs diff=lfs merge=lfs -text

